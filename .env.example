# 统一模型（两套实现共用，通过 litellm 路由）
# 格式：<provider>/<model-name>，与 litellm 字符串格式一致
# 例：anthropic/claude-sonnet-4-6 | openai/gpt-4o | gemini/gemini-2.5-flash
CR_MODEL=openai/your-model-name

# 自定义模型端点（使用标准 provider 时留空或删除此行）
CR_BASE_URL=https://your-endpoint/v1

# 对应的 API Key
CR_API_KEY=sk-...

# Git 平台（选其一）
GITHUB_TOKEN=ghp_...
GITLAB_TOKEN=glpat-...
GITLAB_URL=https://gitlab.com   # 私有部署则改为内网地址

# Langfuse 可观测性（可选，填入后自动上报 token 用量/延迟/费用）
# 从 https://cloud.langfuse.com 或自托管实例获取
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com  # 自托管则改为内网地址
